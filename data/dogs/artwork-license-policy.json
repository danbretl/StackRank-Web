  "sourceRules": {
    "approvedProviders": [
      "wikimedia-commons"
    ],
    "openverseIsDiscoveryOnly": true,
    "requireOriginalByteHash": true,
    "requireHumanRightsReview": true,
    "requireHumanSubjectReview": true,
    "rejectNonCommercial": true,
    "rejectNoDerivatives": true,
    "rejectUnverifiedLicenseChain": true,
    "rejectProvenanceFreeImages": true,
    "rejectAiGeneratedBreedSubstitutes": true
  },
  "openverseNotice": {
    "requiredIfDiscoveryProducesShippedAssets": true,
    "text": "Artwork discovery used Openverse. StackRank is not endorsed or certified by Openverse.",
    "note": "Openverse metadata never establishes rights; the original source must still be verified independently."
  },
  "purposeGates": {
    "uiDisplay": {
      "enabled": true,
      "reviewedAt": "2026-07-16",
      "note": "Allowed only for approved ledger rows delivered from a byte-verified immutable asset variant."
    },
    "publicSnapshot": {
      "enabled": false,
      "reviewedAt": null,
      "note": "Blocked until snapshot attribution, takedown, and ShareAlike handling are separately reviewed and tested."
    },
    "rasterExport": {
      "enabled": false,
      "reviewedAt": null,
      "note": "Blocked until attribution survives every PNG/ZIP path and a ShareAlike adaptation strategy is separately reviewed."
    }
  },
  "launchThresholds": {
    "promotedUiCoverage": 1,
    "currentCanonicalUiCoverage": 0.95
  },
